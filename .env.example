# Example environment variables (do NOT commit real keys)
# Copy this to .env and fill in your actual keys, then `source .env` or use direnv.

# Cactus API key (from https://cactuscompute.com/dashboard/api-keys)
# CACTUS_API_KEY=your-cactus-key-here

# Gemini API key (from Google AI Studio)
# GEMINI_API_KEY=your-gemini-key-here

# Hugging Face API key (if needed)
# HUGGINGFACE_API_KEY=your-hf-key-here
