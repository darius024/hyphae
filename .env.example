# Hyphae environment variables
# Copy to ../.env (repo root) and fill in your values.

# ── Required ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Optional ──────────────────────────────────────────────────────────
# CLOUD_ONLY=1                    # Skip on-device inference, use Gemini for everything
# HYPHAE_CORPUS=/path/to/corpus   # Custom corpus directory (default: hyphae/corpus/)
# FUNCTIONGEMMA_PATH=/path/to/model  # Path to FunctionGemma GGUF weights
# USE_DUMMY_EMBED=1               # Use random vectors instead of real embeddings (dev mode)
# CORS_ORIGINS=http://localhost:3000,https://app.example.com  # Allowed CORS origins
# HOST=127.0.0.1                  # Server bind address
# PORT=5000                       # Server port
# LOG_LEVEL=info                  # Uvicorn log level
# RATE_LIMIT_RPM=120              # Global requests per minute per IP
# RATE_LIMIT_AUTH_RPM=10          # Login/signup requests per minute per IP
